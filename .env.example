# Supabase — get values from: https://supabase.com/dashboard/project/<project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public origin used for absolute OG / canonical URLs (no trailing slash).
# Local dev: http://localhost:3000 — production: https://your-domain.tld
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Admin area (all server-only — NEVER prefix with NEXT_PUBLIC_) ---

# Comma-separated emails allowed into /admin
ADMIN_EMAILS=

# Supabase service role key (Dashboard → Settings → API). Bypasses RLS — server-only.
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 (Dashboard → R2 → Manage API Tokens)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL of the bucket, no trailing slash (custom domain or https://pub-xxxx.r2.dev)
R2_PUBLIC_BASE_URL=
